@page "/"
@using NasreddinsCameraArcanum
@using Markdig
@inject HttpClient Http

<PageTitle>Startseite</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4 home-hero" Elevation="1">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5">Willkommen bei Nasreddins Camera Arcanum</MudText>
            <MudText Typo="Typo.body1">
                Version @BuildInfo.BuildVersion - @BuildInfo.BuildDate @BuildInfo.BuildTime Uhr
            </MudText>
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.PlayArrow" Class="mt-2" FullWidth="true" Href="camera-arcanum">
                Jetzt starten
            </MudButton>
        </MudStack>
    </MudPaper>
    <MudPaper Class="pa-4 home-intro" Elevation="0">
        @if (ladeFehler != null)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-2">@ladeFehler</MudAlert>
        }
        <div class="markdown-content">@((MarkupString)htmlInhalt)</div>
    </MudPaper>
</MudStack>

@code {
    private string htmlInhalt = string.Empty;
    private string? ladeFehler;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var markdownText = await Http.GetStringAsync("texts/intro.md");
            htmlInhalt = Markdown.ToHtml(markdownText);
        }
        catch (Exception exception)
        {
            ladeFehler = $"Die Einführung konnte nicht geladen werden: {exception.Message}";
        }
    }
}
