@page "/"
@using NasreddinsCameraArcanum

<PageTitle>Startseite</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4 home-hero" Elevation="1">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5">Willkommen bei Nasreddins Camera Arcanum</MudText>
            <MudText Typo="Typo.body1">
                Version @BuildInfo.BuildVersion - @BuildInfo.BuildDate @BuildInfo.BuildTime Uhr
            </MudText>
            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.PlayArrow" Class="mt-2" FullWidth="true" Href="camera-arcanum">
                Jetzt starten
            </MudButton>
        </MudStack>
    </MudPaper>
</MudStack>
