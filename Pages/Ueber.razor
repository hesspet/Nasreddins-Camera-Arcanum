@page "/ueber"
@using Nasreddins_Camera_Arcanum.Helpers
@using Markdig
@inject HttpClient Http

<PageTitle>Der Arcanisten</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4" Elevation="1">
        <div class="markdown-content" style="@_ueberStyle">@((MarkupString)ueberHtmlInhalt)</div>
    </MudPaper>
    <MudPaper Class="pa-4" Elevation="1">
        <div class="markdown-content">@((MarkupString)lizenzenHtmlInhalt)</div>
    </MudPaper>
</MudStack>

@code {
    private string ueberHtmlInhalt = string.Empty;
    private string lizenzenHtmlInhalt = string.Empty;
    private string _ueberStyle = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var ueberMarkdown = await Http.GetStringAsync("texts/Ueber.md");
            var frontmatter = MarkdownFrontmatter.Parsen(ueberMarkdown);
            var stilTeile = new System.Collections.Generic.List<string>();
            if (frontmatter.Schrift != null)
            {
                stilTeile.Add($"--markdown-font: '{frontmatter.Schrift}', serif");
            }
            if (frontmatter.Schriftgroesse != null)
            {
                stilTeile.Add($"--markdown-font-size: {frontmatter.Schriftgroesse}");
            }
            _ueberStyle = string.Join("; ", stilTeile);
            ueberHtmlInhalt = Markdown.ToHtml(frontmatter.Markdown);
        }
        catch
        {
            ueberHtmlInhalt = "<p>Der Text konnte nicht geladen werden.</p>";
        }

        try
        {
            var lizenzenMarkdown = await Http.GetStringAsync("texts/OssLicences.md");
            var frontmatter = MarkdownFrontmatter.Parsen(lizenzenMarkdown);
            lizenzenHtmlInhalt = Markdown.ToHtml(frontmatter.Markdown);
        }
        catch
        {
            lizenzenHtmlInhalt = "<p>Die Lizenzinformationen konnten nicht geladen werden.</p>";
        }
    }
}
