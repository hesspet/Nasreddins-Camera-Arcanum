@page "/impressum"
@using Nasreddins_Camera_Arcanum.Helpers
@using Markdig
@inject HttpClient Http

<PageTitle>Impressum</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4" Elevation="1">
        @if (ladeFehler != null)
        {
            <MudAlert Severity="Severity.Warning" Class="mb-2">@ladeFehler</MudAlert>
        }
        <div class="markdown-content" style="@_markdownStyle">@((MarkupString)htmlInhalt)</div>
    </MudPaper>
</MudStack>

@code {
    private string htmlInhalt = string.Empty;
    private string? ladeFehler;
    private string _markdownStyle = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var markdownText = await Http.GetStringAsync("texts/Impressum.md");
            var frontmatter = MarkdownFrontmatter.Parsen(markdownText);
            var stilTeile = new System.Collections.Generic.List<string>();
            if (frontmatter.Schrift != null)
            {
                stilTeile.Add($"--markdown-font: '{frontmatter.Schrift}', serif");
            }
            if (frontmatter.Schriftgroesse != null)
            {
                stilTeile.Add($"--markdown-font-size: {frontmatter.Schriftgroesse}");
            }
            _markdownStyle = string.Join("; ", stilTeile);
            htmlInhalt = Markdown.ToHtml(frontmatter.Markdown);
        }
        catch (Exception exception)
        {
            ladeFehler = $"Das Impressum konnte nicht geladen werden: {exception.Message}";
        }
    }
}
