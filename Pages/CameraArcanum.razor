@page "/camera-arcanum"
@using Nasreddins_Camera_Arcanum.Components
@using Nasreddins_Camera_Arcanum.Helpers

<PageTitle>Camera Arcanum</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5">Kameramodus</MudText>
            <MudText Typo="Typo.body2">
                Öffne die Live-Vorschau, löse per großem Kameraknopf aus und sieh dir dein Foto direkt danach in der Vorschau an.
            </MudText>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
    }

    @if (string.IsNullOrEmpty(_capturedPhoto))
    {
        <CameraView OnCapture="HandleCapture" />
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_lastSavedPath))
        {
            <MudAlert Severity="@(_persistedToFilesystem ? Severity.Success : Severity.Info)" Icon="@Icons.Material.Filled.Save">
                @if (_persistedToFilesystem)
                {
                    <text>Foto gespeichert unter: @_lastSavedPath</text>
                }
                else
                {
                    <text>Foto als Download bereitgestellt: @_lastSavedPath</text>
                }
            </MudAlert>
        }

        <PhotoPreview PhotoDataUrl="_capturedPhoto" OnRetake="ResetCapture" />
    }
</MudStack>

@code {
    private string? _capturedPhoto;
    private string? _errorMessage;
    private string? _lastSavedPath;
    private bool _persistedToFilesystem;

    [Inject]
    private FotoStorage FotoStorage { get; set; } = default!;

    private async Task HandleCapture(string? photo)
    {
        _errorMessage = null;

        try
        {
            var storedPhoto = await FotoStorage.SavePhotoAsync(photo);
            _capturedPhoto = storedPhoto.PreviewDataUrl;
            _lastSavedPath = storedPhoto.FilePath;
            _persistedToFilesystem = storedPhoto.PersistedToFilesystem;
        }
        catch (Exception ex)
        {
            _capturedPhoto = null;
            _errorMessage = ex.Message;
            _lastSavedPath = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task ResetCapture()
    {
        _capturedPhoto = null;
        _errorMessage = null;
        _lastSavedPath = null;
        _persistedToFilesystem = false;
        await InvokeAsync(StateHasChanged);
    }
}
