@page "/camera-arcanum"
@using Nasreddins_Camera_Arcanum.Components
@using Nasreddins_Camera_Arcanum.Helpers
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Camera Arcanum</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5">Kameramodus</MudText>
            <MudText Typo="Typo.body2">
                Öffne die Live-Vorschau, löse per großem Kameraknopf aus und sieh dir dein Foto direkt danach in der Vorschau an.
            </MudText>
            <MudText Typo="Typo.body2">
                Alternativ kannst du ein vorhandenes Bild hochladen, um die Verarbeitung ohne Live-Kamera zu testen.
            </MudText>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
    }

    @if (string.IsNullOrEmpty(_capturedPhoto))
    {
        <MudGrid Spacing="2">
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudText Typo="Typo.subtitle1" Class="mb-2">Live-Foto aufnehmen</MudText>
                    <CameraView OnCapture="HandleCapture" />
                </MudPaper>
            </MudItem>
            <MudItem xs="12" md="6">
                <MudPaper Class="pa-4" Elevation="1">
                    <MudStack Spacing="1">
                        <MudText Typo="Typo.subtitle1">Bild hochladen</MudText>
                        <MudText Typo="Typo.body2">
                            Ziehe eine Bilddatei hierher oder wähle sie aus deinem Dateisystem aus. Unterstützte Formate: PNG, JPG, GIF, WEBP (max. 10 MB).
                        </MudText>
                        <MudFileUpload T="IBrowserFile" FilesChanged="@HandleFileSelected" Accept="image/*" MaxFileSize="10485760" ButtonText="Datei auswählen" ChipColor="Color.Primary" Dense="true" />
                    </MudStack>
                </MudPaper>
            </MudItem>
        </MudGrid>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_lastSavedPath))
        {
            <MudAlert Severity="@(_persistedToFilesystem ? Severity.Success : Severity.Info)" Icon="@Icons.Material.Filled.Save">
                @if (_persistedToFilesystem)
                {
                    <text>Foto gespeichert unter: @_lastSavedPath</text>
                }
                else
                {
                    <text>Foto im Browser zwischengespeichert (@_lastSavedPath)</text>
                }
            </MudAlert>
        }

        <PhotoPreview PhotoDataUrl="@_capturedPhoto" OnRetake="@ResetCapture" />
    }
</MudStack>

@code {
    private const long MaxUploadSize = 10 * 1024 * 1024;
    private static readonly string[] AllowedContentTypes =
    {
        "image/jpeg",
        "image/png",
        "image/gif",
        "image/webp"
    };

    private string? _capturedPhoto;
    private string? _errorMessage;
    private string? _lastSavedPath;
    private bool _persistedToFilesystem;

    [Inject]
    private FotoStorage FotoStorage { get; set; } = default!;

    private async Task HandleCapture(string? photo)
    {
        _errorMessage = null;

        try
        {
            var storedPhoto = await FotoStorage.SavePhotoAsync(photo);
            _capturedPhoto = storedPhoto.PreviewDataUrl;
            _lastSavedPath = storedPhoto.FilePath;
            _persistedToFilesystem = storedPhoto.PersistedToFilesystem;
        }
        catch (Exception ex)
        {
            _capturedPhoto = null;
            _errorMessage = ex.Message;
            _lastSavedPath = null;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleFileSelected(IEnumerable<IBrowserFile> files)
    {
        if (files is null)
        {
            return;
        }

        var file = files.FirstOrDefault();
        if (file is null)
        {
            return;
        }
        _errorMessage = null;

        if (!IsSupportedImage(file))
        {
            _errorMessage = "Bitte wähle eine gültige Bilddatei aus (PNG, JPG, GIF, WEBP).";
            await InvokeAsync(StateHasChanged);
            return;
        }

        try
        {
            var dataUrl = await ReadFileAsDataUrlAsync(file);
            await HandleCapture(dataUrl);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Hochladen fehlgeschlagen: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    private static bool IsSupportedImage(IBrowserFile file)
    {
        if (AllowedContentTypes.Any(type => string.Equals(type, file.ContentType, StringComparison.OrdinalIgnoreCase)))
        {
            return true;
        }

        var extension = Path.GetExtension(file.Name);
        return extension.ToLowerInvariant() switch
        {
            ".jpeg" or ".jpg" => true,
            ".png" => true,
            ".gif" => true,
            ".webp" => true,
            _ => false,
        };
    }

    private static string GetMimeType(IBrowserFile file)
    {
        if (!string.IsNullOrWhiteSpace(file.ContentType) && file.ContentType.StartsWith("image/", StringComparison.OrdinalIgnoreCase))
        {
            return file.ContentType;
        }

        var extension = Path.GetExtension(file.Name).ToLowerInvariant();
        return extension switch
        {
            ".jpeg" or ".jpg" => "image/jpeg",
            ".gif" => "image/gif",
            ".webp" => "image/webp",
            _ => "image/png",
        };
    }

    private static async Task<string> ReadFileAsDataUrlAsync(IBrowserFile file)
    {
        await using var stream = file.OpenReadStream(MaxUploadSize);
        using var memoryStream = new MemoryStream();
        await stream.CopyToAsync(memoryStream);
        var base64 = Convert.ToBase64String(memoryStream.ToArray());
        var mimeType = GetMimeType(file);
        return $"data:{mimeType};base64,{base64}";
    }

    private async Task ResetCapture()
    {
        _capturedPhoto = null;
        _errorMessage = null;
        _lastSavedPath = null;
        _persistedToFilesystem = false;
        await InvokeAsync(StateHasChanged);
    }
}
