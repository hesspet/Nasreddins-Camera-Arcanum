@page "/setup"
@using Nasreddins_Camera_Arcanum.Helpers
@using NasreddinsCameraArcanum
@inject DarkModeService DarkModeService
@inject FontEinstellungenService FontEinstellungenService
@inject PwaUpdateService PwaUpdateService

<PageTitle>Segmentierungs-Einstellungen</PageTitle>

<MudStack Spacing="2">
    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="1">
            <MudText Typo="Typo.h5">Body-Segmentation einrichten</MudText>
            <MudText Typo="Typo.body2">
                Wähle hier die Parameter für das MediaPipe Selfie Segmentierungsmodell. Die Einstellungen wirken sich direkt auf
                die Vorschau und die erzeugten Vorder-/Hintergrund-Bilder aus.
            </MudText>
            <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary">
                Build @BuildInfo.BuildVersion – @BuildInfo.BuildDate @BuildInfo.BuildTime Uhr
            </MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1">Modell-Parameter</MudText>

            <MudSelect @bind-Value="_options.ModelType" Label="Modellvariante" Variant="Variant.Outlined">
                <MudSelectItem Value="@("general")">General (empfohlen)</MudSelectItem>
                <MudSelectItem Value="@("landscape")">Landscape</MudSelectItem>
            </MudSelect>

            <MudText Typo="Typo.subtitle2">Schwellwert (Personenerkennung)</MudText>
            <MudSlider @bind-Value="_options.SegmentationThreshold"
                        Min="0.05"
                        Max="0.95"
                        Step="0.05"
                        Color="MudBlazor.Color.Secondary"
                        Variant="Variant.Filled"
                        ValueLabel="@true"
                        ValueLabelFormat="0.00">
            </MudSlider>
            <MudText Typo="Typo.caption">
                Höhere Werte bevorzugen klarere Silhouetten, niedrigere Werte fangen mehr Umgebung ein.
            </MudText>

            <MudText Typo="Typo.subtitle2">Maskenweichzeichnung (Pixel)</MudText>
            <MudSlider @bind-Value="_options.MaskBlurAmount"
                        Min="0"
                        Max="20"
                        Step="1"
                        Color="MudBlazor.Color.Secondary"
                        Variant="Variant.Filled"
                        ValueLabel="@true"
                        ValueLabelFormat="0">
            </MudSlider>
            <MudText Typo="Typo.caption">
                Der Unschärferadius glättet die Kanten zwischen Person und Hintergrund.
            </MudText>

            <MudText Typo="Typo.subtitle2">Masken-Dilatation (Pixel)</MudText>
            <MudSlider @bind-Value="_options.DilationRadius"
                        Min="0"
                        Max="10"
                        Step="1"
                        Color="MudBlazor.Color.Secondary"
                        Variant="Variant.Filled"
                        ValueLabel="@true"
                        ValueLabelFormat="0">
            </MudSlider>
            <MudText Typo="Typo.caption">
                Erweitert die Maske geringfügig, um kleine Löcher zu schließen.
            </MudText>

            <MudText Typo="Typo.subtitle2">Masken-Erosion (Pixel)</MudText>
            <MudSlider @bind-Value="_options.ErosionRadius"
                        Min="0"
                        Max="10"
                        Step="1"
                        Color="MudBlazor.Color.Secondary"
                        Variant="Variant.Filled"
                        ValueLabel="@true"
                        ValueLabelFormat="0">
            </MudSlider>
            <MudText Typo="Typo.caption">
                Verkleinert die Maske leicht, um Rauschen am Rand zu entfernen.
            </MudText>

            <MudText Typo="Typo.subtitle2">Weiche Kante innen (Pixel)</MudText>
            <MudSlider @bind-Value="_options.InnerFeatherRadius"
                        Min="0"
                        Max="20"
                        Step="1"
                        Color="MudBlazor.Color.Secondary"
                        Variant="Variant.Filled"
                        ValueLabel="@true"
                        ValueLabelFormat="0">
            </MudSlider>
            <MudText Typo="Typo.caption">
                Weichzeichner für die Innenkante der Person, um Halos zu minimieren.
            </MudText>

            <MudText Typo="Typo.subtitle2">Weiche Kante außen (Pixel)</MudText>
            <MudSlider @bind-Value="_options.OuterFeatherRadius"
                        Min="0"
                        Max="30"
                        Step="1"
                        Color="MudBlazor.Color.Secondary"
                        Variant="Variant.Filled"
                        ValueLabel="@true"
                        ValueLabelFormat="0">
            </MudSlider>
            <MudText Typo="Typo.caption">
                Federt die Außenkante ab und steuert die sichtbare Übergangsbreite zum Hintergrund.
            </MudText>

            <MudStack Row="true" Spacing="1">
                <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="ApplySettings">
                    Einstellungen übernehmen
                </MudButton>
                <MudButton Variant="Variant.Text" Color="MudBlazor.Color.Default" StartIcon="@Icons.Material.Filled.Restore" OnClick="ResetDefaults">
                    Auf Standard zurücksetzen
                </MudButton>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1">Darstellung</MudText>
            <MudSwitch T="bool" Value="_istDarkMode"
                       ValueChanged="@BeiDarkModeUmschalten"
                       Label="Darkmode"
                       Color="MudBlazor.Color.Primary" />
            <MudText Typo="Typo.caption">
                Schaltet zwischen hellem und dunklem Erscheinungsbild um. Die Einstellung wird automatisch gespeichert.
            </MudText>

            <MudDivider Class="my-2" />

            <MudText Typo="Typo.subtitle2">Schriftart für Texte</MudText>
            <MudSelect T="string" Value="_ausgewaehlteSchriftCss"
                       ValueChanged="@BeiSchriftAuswahl"
                       Label="Schrift auswählen"
                       Variant="Variant.Outlined"
                       AnchorOrigin="Origin.BottomCenter">
                <MudSelectItem Value="@("")">App-Standard</MudSelectItem>
                <MudDivider />
                <MudSelectItem Value="@("")" Disabled="true">
                    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary"><strong>Mittelalter / Fantasy</strong></MudText>
                </MudSelectItem>
                @foreach (var schrift in VerfuegbareSchriften.FantasySchriften)
                {
                    <MudSelectItem Value="@schrift.CssWert">@schrift.AnzeigeName</MudSelectItem>
                }
                <MudDivider />
                <MudSelectItem Value="@("")" Disabled="true">
                    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary"><strong>Web-Standard</strong></MudText>
                </MudSelectItem>
                @foreach (var schrift in VerfuegbareSchriften.WebStandardSchriften)
                {
                    <MudSelectItem Value="@schrift.CssWert">@schrift.AnzeigeName</MudSelectItem>
                }
                <MudDivider />
                <MudSelectItem Value="@("")" Disabled="true">
                    <MudText Typo="Typo.caption" Color="MudBlazor.Color.Secondary"><strong>Generisch</strong></MudText>
                </MudSelectItem>
                @foreach (var schrift in VerfuegbareSchriften.GenerischeSchriften)
                {
                    <MudSelectItem Value="@schrift.CssWert">@schrift.AnzeigeName</MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.caption">
                Wähle eine Schriftart für die Markdown-Texte. „App-Standard“ verwendet die voreingestellte Fantasyschrift.
                Web-Standard-Schriften deaktivieren die Fantasyschriften und nutzen die auf jedem Gerät verfügbaren Systemschriften.
            </MudText>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="1">
        <MudStack Spacing="2">
            <MudText Typo="Typo.subtitle1">App-Aktualisierung</MudText>

            @if (_plattformInfo == null)
            {
                <MudText Typo="Typo.body2">Plattform-Informationen werden ermittelt...</MudText>
            }
            else
            {
                <MudText Typo="Typo.body2">
                    Erkannte Plattform: <strong>@_plattformInfo.Platform</strong> –
                    @(_plattformInfo.IsInstalledPwa ? "Installierte PWA" : "Browser")
                </MudText>

                @if (_plattformInfo.IsInstalledPwa && _plattformInfo.Platform == "ios")
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                        <MudStack Spacing="1">
                            <MudText Typo="Typo.body2">
                                <strong>iOS-Hinweis:</strong> Bei installierten PWAs kann das automatische Update eingeschränkt sein.
                                Falls der Button nicht zum Erfolg führt, schließe die App vollständig
                                (aus dem App-Umschalter wischen) und öffne sie erneut.
                            </MudText>
                        </MudStack>
                    </MudAlert>
                }

                @if (!string.IsNullOrEmpty(_updateNachricht))
                {
                    <MudAlert Severity="@(_updateErfolgreich ? Severity.Success : Severity.Error)" Variant="Variant.Outlined">
                        @_updateNachricht
                    </MudAlert>
                }

                <MudButton Variant="Variant.Filled"
                           Color="MudBlazor.Color.Primary"
                           StartIcon="@Icons.Material.Filled.Update"
                           OnClick="UpdateErzwingen"
                           Disabled="@_updateInProgress">
                    Update erzwingen
                </MudButton>
            }
        </MudStack>
    </MudPaper>
</MudStack>

@code {
    private readonly SegmentationOptions _options = new();
    private bool _istDarkMode;
    private string _ausgewaehlteSchriftCss = string.Empty;

    private PwaPlattformInfo? _plattformInfo;
    private bool _updateInProgress;
    private string _updateNachricht = string.Empty;
    private bool _updateErfolgreich;

    [Inject]
    private SegmentationSettings Settings { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        await Settings.EnsureInitializedAsync();
        CopyFrom(Settings.Options, _options);

        await DarkModeService.StelleSicherInitialisiertAsync();
        _istDarkMode = DarkModeService.IstDarkMode;
        DarkModeService.DarkModeGeändert += BeiDarkModeGeändert;

        await FontEinstellungenService.StelleSicherInitialisiertAsync();
        _ausgewaehlteSchriftCss = FontEinstellungenService.GewaehlteSchriftCss;
        FontEinstellungenService.SchriftGeaendert += BeiSchriftGeaendert;

        // Plattform-Info für den Update-Block ermitteln
        try { _plattformInfo = await PwaUpdateService.ErmittlePlattformInfoAsync(); }
        catch { /* Fehler bei Plattform-Erkennung – Block zeigt dann Ladezustand */ }
    }

    private async Task ApplySettings()
    {
        await Settings.UpdateAsync(_options);
        Snackbar.Add("Segmentierungs-Einstellungen aktualisiert", Severity.Success);
    }

    private async Task ResetDefaults()
    {
        CopyFrom(new SegmentationOptions(), _options);
        await Settings.UpdateAsync(_options);
        Snackbar.Add("Standardwerte wiederhergestellt", Severity.Info);
    }

    private async void BeiDarkModeGeändert(bool istDarkMode)
    {
        _istDarkMode = istDarkMode;
        await InvokeAsync(StateHasChanged);
    }

    private async Task BeiDarkModeUmschalten(bool checkedValue)
    {
        await DarkModeService.SetzeDarkModeAsync(checkedValue);
    }

    private static void CopyFrom(SegmentationOptions source, SegmentationOptions target)
    {
        target.ModelType = source.ModelType;
        target.SegmentationThreshold = source.SegmentationThreshold;
        target.MaskBlurAmount = source.MaskBlurAmount;
        target.DilationRadius = source.DilationRadius;
        target.ErosionRadius = source.ErosionRadius;
        target.InnerFeatherRadius = source.InnerFeatherRadius;
        target.OuterFeatherRadius = source.OuterFeatherRadius;
    }

    private async Task BeiSchriftAuswahl(string cssWert)
    {
        _ausgewaehlteSchriftCss = cssWert;
        var eintrag = VerfuegbareSchriften.Alle.FirstOrDefault(f => f.CssWert == cssWert);
        var anzeigeName = eintrag.AnzeigeName ?? "App-Standard";
        await FontEinstellungenService.SetzeSchriftAsync(cssWert, anzeigeName);
    }

    private async void BeiSchriftGeaendert()
    {
        _ausgewaehlteSchriftCss = FontEinstellungenService.GewaehlteSchriftCss;
        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateErzwingen()
    {
        _updateInProgress = true;
        _updateNachricht = "Suche nach Updates...";
        _updateErfolgreich = true;

        try
        {
            var ergebnis = await PwaUpdateService.UpdateErzwingenAsync();
            _updateErfolgreich = ergebnis.Success;
            _updateNachricht = ergebnis.Message;

            if (ergebnis.Success && ergebnis.Reload)
            {
                // Der Reload wird vom JS controllerchange-Handler ausgelöst.
                _updateInProgress = false;
            }
        }
        catch (Exception ex)
        {
            _updateErfolgreich = false;
            _updateNachricht = $"Fehler bei der Aktualisierung: {ex.Message}";
        }
        finally
        {
            _updateInProgress = false;
        }
    }
}