@using Nasreddins_Camera_Arcanum.Helpers
@inject DarkModeService DarkModeService
@implements IDisposable

<MudThemeProvider Theme="@_thema"
                  IsDarkMode="@DarkModeService.IstDarkMode"
                  IsDarkModeChanged="@BeiDarkModeGeändert" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="main" />
    </Found>
    <NotFound>
        <PageTitle>Nicht gefunden</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Error">Unter dieser Adresse wurde keine Seite gefunden.</MudText>
                <MudText Typo="Typo.body2">Nutze das Menü, um zur Startseite zurückzukehren.</MudText>
            </MudPaper>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private readonly MudTheme _thema = new()
    {
        PaletteLight = new PaletteLight
        {
            // Altes Buch / Pergament-Ästhetik
            Primary = "#5D4037",            // Dunkelbraun (Überschriften, Akzente)
            PrimaryDarken = "#4E342E",      // Noch dunkleres Braun
            PrimaryLighten = "#8D6E63",     // Helleres Braun
            Secondary = "#B8860B",          // Dunkles Gold (sekundäre Akzente)
            SecondaryDarken = "#9A7209",    // Tieferes Gold
            SecondaryLighten = "#D4A843",   // Helleres Gold
            Tertiary = "#6D4C41",           // Mittelbraun (tertiär)
            Background = "#F5E6C8",         // Pergament-Hintergrund
            Surface = "#EDE0C8",            // Etwas dunkleres Pergament (Karten)
            DrawerBackground = "#E8D5B0",   // Drawer in warmem Beige
            DrawerText = "#3E2723",         // Dunkelbrauner Drawer-Text
            AppbarBackground = "#4E342E",   // Dunkelbraune App-Bar
            AppbarText = "#F5E6C8",         // Heller Text auf dunkler Bar
            TextPrimary = "#3E2723",        // Fast schwarzer Text
            TextSecondary = "#5D4037",      // Brauner Sekundärtext
            TextDisabled = "#A1887F",       // Ausgegraut
            ActionDefault = "#5D4037",      // Standard-Aktionsfarbe
            ActionDisabled = "#BCAAA4",     // Deaktivierte Aktionsfarbe
            ActionDisabledBackground = "#EFEBE9",
            DrawerIcon = "#5D4037",
            Divider = "#BCAAA4",
            DividerLight = "#D7CCC8",
            LinesDefault = "#8D6E63",
            LinesInputs = "#A1887F",
            OverlayDark = "rgba(62, 39, 35, 0.5)",
            OverlayLight = "rgba(245, 230, 200, 0.5)",
            HoverOpacity = 0.06,
            GrayDefault = "#8D6E63",
            GrayLight = "#D7CCC8",
            GrayLighter = "#EFEBE9",
            GrayDark = "#5D4037",
            GrayDarker = "#3E2723",
        },
        PaletteDark = new PaletteDark
        {
            // Horror-Ästhetik
            Primary = "#8B0000",            // Blutrot (primäre Akzente)
            PrimaryDarken = "#660000",      // Dunkleres Rot
            PrimaryLighten = "#B71C1C",     // Helleres Rot
            Secondary = "#556B2F",         // Olivgrün (krankhafte Akzente)
            SecondaryDarken = "#3E4F22",   // Tieferes Oliv
            SecondaryLighten = "#6B8E3D",  // Helleres Oliv
            Tertiary = "#4A0E0E",          // Tiefes Rotbraun
            Background = "#0D0D0D",         // Fast schwarz
            Surface = "#1A1010",           // Dunkel mit rotem Hauch
            DrawerBackground = "#0F0505",   // Noch dunklerer Drawer
            DrawerText = "#CCBBBB",        // Gräulicher Drawer-Text
            AppbarBackground = "#0F0000",   // Tiefste Dunkelheit mit Rot
            AppbarText = "#E0D0D0",        // Blasser Text
            TextPrimary = "#E0D0D0",       // Blasser Primärtext
            TextSecondary = "#A09090",     // Gedämpfter Sekundärtext
            TextDisabled = "#554444",
            ActionDefault = "#8B0000",
            ActionDisabled = "#3A2020",
            ActionDisabledBackground = "#1A1010",
            DrawerIcon = "#8B0000",
            Divider = "#3A2020",
            DividerLight = "#2A1515",
            LinesDefault = "#554444",
            LinesInputs = "#664444",
            OverlayDark = "rgba(0, 0, 0, 0.7)",
            OverlayLight = "rgba(139, 0, 0, 0.15)",
            HoverOpacity = 0.08,
            GrayDefault = "#554444",
            GrayLight = "#3A2020",
            GrayLighter = "#2A1515",
            GrayDark = "#664444",
            GrayDarker = "#886666",
        }
    };

    protected override async Task OnInitializedAsync()
    {
        await DarkModeService.StelleSicherInitialisiertAsync();
        DarkModeService.DarkModeGeändert += BeiDarkModeExternGeändert;
    }

    private async Task BeiDarkModeGeändert(bool istDarkMode)
    {
        await DarkModeService.SetzeDarkModeAsync(istDarkMode);
        StateHasChanged();
    }

    private async void BeiDarkModeExternGeändert(bool istDarkMode)
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        DarkModeService.DarkModeGeändert -= BeiDarkModeExternGeändert;
    }
}
