<MudThemeProvider Theme="@_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<Router AppAssembly="@typeof(App).Assembly">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
        <FocusOnNavigate RouteData="@routeData" Selector="main" />
    </Found>
    <NotFound>
        <PageTitle>Nicht gefunden</PageTitle>
        <LayoutView Layout="@typeof(MainLayout)">
            <MudPaper Class="pa-4" Elevation="1">
                <MudText Typo="Typo.h6" Color="MudBlazor.Color.Error">Unter dieser Adresse wurde keine Seite gefunden.</MudText>
                <MudText Typo="Typo.body2">Nutze das Menü, um zur Startseite zurückzukehren.</MudText>
            </MudPaper>
        </LayoutView>
    </NotFound>
</Router>

@code {
    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = Colors.Blue.Darken3,
            Secondary = Colors.Cyan.Darken3,
            Background = Colors.Gray.Lighten5,
            AppbarBackground = Colors.Blue.Darken3,
        }
    };
}
