@inherits LayoutComponentBase

<MudLayout>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always" Class="drawer">
        <MudStack Spacing="1" Class="drawer-content">
            <MudText Typo="Typo.subtitle2" Color="MudBlazor.Color.Primary" Class="ms-2 mt-1">Navigation</MudText>
            <MudNavMenu Dense="true">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
                <MudNavLink Href="/camera-arcanum" Icon="@Icons.Material.Filled.PhotoCamera">Camera</MudNavLink>
                <MudNavLink Href="/setup" Icon="@Icons.Material.Filled.Tune">Setup</MudNavLink>
            </MudNavMenu>
        </MudStack>
    </MudDrawer>

    <MudMainContent>
        <MudAppBar Elevation="4" Color="MudBlazor.Color.Primary">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="MudBlazor.Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
            <MudText Typo="Typo.h6" Class="ms-2">Nasreddin's Camera Arcanum</MudText>
        </MudAppBar>
        <main class="content-frame" id="main-content">
            @Body
        </main>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen;

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
