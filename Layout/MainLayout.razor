@inherits LayoutComponentBase
@using Nasreddins_Camera_Arcanum.Helpers
@inject FontEinstellungenService FontEinstellungenService

<MudLayout>
    <MudDrawer @bind-Open="_drawerOpen" Elevation="1" Variant="DrawerVariant.Responsive" ClipMode="DrawerClipMode.Always" Class="drawer">
        <MudStack Spacing="1" Class="drawer-content">
            <MudText Typo="Typo.subtitle2" Color="MudBlazor.Color.Primary" Class="ms-2 mt-1">Navigation</MudText>
            <MudNavMenu Dense="true">
                <MudNavLink Href="./" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Startseite</MudNavLink>
                <MudNavLink Href="camera-arcanum" Icon="@Icons.Material.Filled.PhotoCamera">Kamera</MudNavLink>
                <MudNavLink Href="kamera-pur" Icon="@Icons.Material.Filled.CameraAlt">Kamera Pur</MudNavLink>
                <MudNavLink Href="setup" Icon="@Icons.Material.Filled.Tune">Einstellungen</MudNavLink>
                <MudNavLink Href="ueber" Icon="@Icons.Material.Filled.Info">Über</MudNavLink>
            </MudNavMenu>
        </MudStack>
    </MudDrawer>

    <MudMainContent>
        <MudAppBar Elevation="4" Color="MudBlazor.Color.Primary">
            <MudIconButton Color="MudBlazor.Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer">
                <span class="zodiac-menu-icon">@_sternzeichenBuchstabe</span>
            </MudIconButton>
            <MudText Typo="Typo.h6" Class="ms-2">Nasreddin's Camera Arcanum</MudText>
        </MudAppBar>
        <main class="content-frame" id="main-content" style="@_fontVariableStyle">
            @Body
        </main>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen;
    private string _fontVariableStyle = string.Empty;
    private string _sternzeichenBuchstabe = "C";

    protected override async Task OnInitializedAsync()
    {
        _sternzeichenBuchstabe = SternzeichenHelper.HeutigesSternzeichenBuchstabe().ToString();

        await FontEinstellungenService.StelleSicherInitialisiertAsync();
        AktualisiereFontStyle();
        FontEinstellungenService.SchriftGeaendert += BeiSchriftGeaendert;
    }

    private void AktualisiereFontStyle()
    {
        if (!string.IsNullOrEmpty(FontEinstellungenService.GewaehlteSchriftCss))
        {
            _fontVariableStyle = $"--font-fantasy: {FontEinstellungenService.GewaehlteSchriftCss}";
        }
        else
        {
            _fontVariableStyle = string.Empty;
        }
    }

    private async void BeiSchriftGeaendert()
    {
        AktualisiereFontStyle();
        await InvokeAsync(StateHasChanged);
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }
}
