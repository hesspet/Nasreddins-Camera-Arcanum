@implements IAsyncDisposable

<MudPaper Class="overlay-carousel" Elevation="1">
    <MudStack Spacing="2">
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
            <MudIcon Icon="@Icons.Material.Filled.Collections" Color="MudBlazor.Color.Primary" />
            <MudText Typo="Typo.subtitle1">Zwischenschicht auswählen</MudText>
        </MudStack>

        @if (_isLoading)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-4" Spacing="1">
                <MudProgressCircular Indeterminate="true" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Medium" />
                <MudText Typo="Typo.body2">Zwischenschichten werden geladen.</MudText>
            </MudStack>
        }
        else if (_overlays.Count == 0)
        {
            <MudText Typo="Typo.body2" Class="mud-secondary-text">Keine Zwischenschichten gefunden.</MudText>
        }
        else
        {
            <div class="carousel-stage" @onpointerdown="HandlePointerDown" @onpointerup="HandlePointerUp">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Color="MudBlazor.Color.Primary" OnClick="PreviousAsync" Disabled="@(!_canNavigate)" />
                <div class="carousel-image-wrapper">
                    <img src="@CurrentOverlay?.Path" alt="@CurrentOverlay?.Title" class="carousel-image" @ondblclick="ProceedAsync" />
                    <div class="carousel-caption">@CurrentOverlay?.Title</div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Color="MudBlazor.Color.Primary" OnClick="NextAsync" Disabled="@(!_canNavigate)" />
            </div>

            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Spacing="1">
                <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Primary" OnClick="PreviousAsync" Disabled="@(!_canNavigate)" StartIcon="@Icons.Material.Filled.NavigateBefore">
                    Zurück
                </MudButton>
                <div class="overlay-choice-list">
                    @for (var i = 0; i < _overlays.Count; i++)
                    {
                        var overlayIndex = i;
                        var overlay = _overlays[overlayIndex];
                        var isActive = i == _currentIndex;
                        <MudButton Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                                   Color="@(isActive ? MudBlazor.Color.Primary : MudBlazor.Color.Default)"
                                   Size="MudBlazor.Size.Small"
                                   Class="overlay-choice-button"
                                   OnClick="@(() => SelectIndexAsync(overlayIndex))">
                            @overlay.Title
                        </MudButton>
                    }
                </div>
                <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Primary" OnClick="NextAsync" Disabled="@(!_canNavigate)" EndIcon="@Icons.Material.Filled.NavigateNext">
                    Weiter
                </MudButton>
            </MudStack>

            <MudSwitch T="bool" Value="@_useOriginalBackground" ValueChanged="HandleBackgroundToggleAsync" Color="MudBlazor.Color.Primary" Label="Originalbild als Hintergrund verwenden" />

            <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.CheckCircle" OnClick="ProceedAsync">
                Auswahl bestätigen
            </MudButton>
            <MudText Typo="Typo.caption" Class="mud-secondary-text">
                Tipp: Doppelklick auf das Bild oder den Button bestätigt die Auswahl.
            </MudText>
        }
    </MudStack>
</MudPaper>

@code {
    private const string StorageKey = "merge-overlay-last-selection";
    private const string BackgroundPreferenceKey = "merge-overlay-background-mode";

    private IReadOnlyList<MergeOverlay> _overlays = Array.Empty<MergeOverlay>();
    private int _currentIndex;
    private double? _pointerStartX;
    private bool _useOriginalBackground;
    private bool _isLoading = true;
    private IJSObjectReference? _overlayModule;

    [Parameter]
    public EventCallback<OverlayProceedRequest> OnProceed { get; set; }

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    private bool _canNavigate => _overlays.Count > 1;

    private MergeOverlay? CurrentOverlay => _overlays.Count > 0 && _currentIndex >= 0 && _currentIndex < _overlays.Count
        ? _overlays[_currentIndex]
        : null;

    protected override async Task OnInitializedAsync()
    {
        _overlays = await LoadOverlaysAsync();
        await RestoreSelectionAsync();
        await RestoreBackgroundPreferenceAsync();
        _isLoading = false;
    }

    private async Task RestoreSelectionAsync()
    {
        var storedPath = await GetStoredPathAsync();
        var storedIndex = FindIndexByPath(storedPath);
        _currentIndex = storedIndex >= 0 ? storedIndex : 0;
    }

    private async Task RestoreBackgroundPreferenceAsync()
    {
        _useOriginalBackground = await GetStoredBackgroundPreferenceAsync();
    }

    private int FindIndexByPath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return -1;
        }

        for (var i = 0; i < _overlays.Count; i++)
        {
            if (string.Equals(_overlays[i].Path, path, StringComparison.OrdinalIgnoreCase))
            {
                return i;
            }
        }

        return -1;
    }

    private async Task<string?> GetStoredPathAsync()
    {
        try
        {
            return await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey);
        }
        catch
        {
            return null;
        }
    }

    private async Task PersistSelectionAsync()
    {
        if (CurrentOverlay is null)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey, CurrentOverlay.Path);
        }
        catch
        {
            // Persistence is best-effort only.
        }
    }

    private async Task<bool> GetStoredBackgroundPreferenceAsync()
    {
        try
        {
            var stored = await JS.InvokeAsync<string?>("localStorage.getItem", BackgroundPreferenceKey);
            return string.Equals(stored, "original", StringComparison.OrdinalIgnoreCase)
                || string.Equals(stored, "true", StringComparison.OrdinalIgnoreCase);
        }
        catch
        {
            return false;
        }
    }

    private async Task PersistBackgroundPreferenceAsync()
    {
        var value = _useOriginalBackground ? "original" : "extracted";

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", BackgroundPreferenceKey, value);
        }
        catch
        {
            // Persistence is best-effort only.
        }
    }

    private Task SelectIndexAsync(int index)
    {
        _currentIndex = NormalizeIndex(index);
        return PersistSelectionAsync();
    }

    private int NormalizeIndex(int index)
    {
        if (_overlays.Count == 0)
        {
            return 0;
        }

        if (index < 0)
        {
            return _overlays.Count - 1;
        }

        if (index >= _overlays.Count)
        {
            return 0;
        }

        return index;
    }

    private async Task NextAsync()
    {
        await SelectIndexAsync(_currentIndex + 1);
    }

    private async Task PreviousAsync()
    {
        await SelectIndexAsync(_currentIndex - 1);
    }

    private void HandlePointerDown(PointerEventArgs args)
    {
        _pointerStartX = args.ClientX;
    }

    private async Task HandlePointerUp(PointerEventArgs args)
    {
        if (_pointerStartX is null)
        {
            return;
        }

        var deltaX = args.ClientX - _pointerStartX.Value;
        _pointerStartX = null;

        const double swipeThreshold = 25;

        if (Math.Abs(deltaX) < swipeThreshold)
        {
            return;
        }

        if (deltaX < 0)
        {
            await NextAsync();
        }
        else
        {
            await PreviousAsync();
        }
    }

    private async Task HandleBackgroundToggleAsync(bool useOriginal)
    {
        _useOriginalBackground = useOriginal;
        await PersistBackgroundPreferenceAsync();
    }

    private async Task ProceedAsync()
    {
        if (CurrentOverlay is null)
        {
            return;
        }

        await PersistSelectionAsync();
        await PersistBackgroundPreferenceAsync();
        await OnProceed.InvokeAsync(new OverlayProceedRequest(CurrentOverlay.Path, _useOriginalBackground));
    }

    private async Task<IReadOnlyList<MergeOverlay>> LoadOverlaysAsync()
    {
        try
        {
            _overlayModule = await JS.InvokeAsync<IJSObjectReference>("import", "./js/mergeOverlays.js");
            var overlays = await _overlayModule.InvokeAsync<MergeOverlay[]>("getMergeOverlays");
            return overlays
                .Where(overlay => !string.IsNullOrWhiteSpace(overlay.Path) && !string.IsNullOrWhiteSpace(overlay.Title))
                .ToList();
        }
        catch
        {
            return Array.Empty<MergeOverlay>();
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_overlayModule is not null)
        {
            try
            {
                await _overlayModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignored because the JS runtime is no longer available.
            }
        }
    }
}
