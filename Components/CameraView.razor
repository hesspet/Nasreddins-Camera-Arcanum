@using Microsoft.JSInterop

<div class="camera-frame">
    <video @ref="_videoRef" class="camera-video" autoplay playsinline muted></video>
    <MudStack Row="true" JustifyContent="JustifyContent.Center" Class="mt-2">
        <MudFab Color="MudBlazor.Color.Primary" Icon="@Icons.Material.Filled.PhotoCamera" Size="MudBlazor.Size.Large" OnClick="CapturePhoto" />
    </MudStack>
</div>

@code {
    [Parameter]
    public EventCallback<string?> OnCapture { get; set; }

    private ElementReference _videoRef;
    private IJSObjectReference? _module;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/cameraArcanum.js");
            await _module.InvokeVoidAsync("startCamera", _videoRef);
        }
    }

    private async Task CapturePhoto()
    {
        if (_module is null)
        {
            return;
        }

        var photoData = await _module.InvokeAsync<string?>("captureFrame", _videoRef);
        await OnCapture.InvokeAsync(photoData);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("stopCamera", _videoRef);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Ignored because the JS runtime is no longer available
            }
        }
    }
}
