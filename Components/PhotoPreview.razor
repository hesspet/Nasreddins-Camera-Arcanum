@implements IAsyncDisposable
@using SixLabors.ImageSharp
@using System.Globalization
@using Nasreddins_Camera_Arcanum.Helpers

<MudPaper Class="photo-preview" Elevation="2">
    @if (!string.IsNullOrEmpty(PhotoDataUrl))
    {
        <div class="photo-wrapper">
            <img @ref="_photoRef" src="@PhotoDataUrl" alt="Aufgenommenes Foto" class="photo-image" @onclick="HandleImageClick" />
            <div class="photo-hint">Auf das Motiv tippen, um die Segmentierung zu starten.</div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_segmentationError))
    {
        <MudAlert Severity="Severity.Error" Dense="true">@_segmentationError</MudAlert>
    }

    <MudStack Row="true" Spacing="2" JustifyContent="JustifyContent.Center" Class="mt-2">
        <MudButton Variant="Variant.Filled" Color="MudBlazor.Color.Primary" StartIcon="@Icons.Material.Filled.Replay" OnClick="HandleRetake">
            Nochmals aufnehmen
        </MudButton>
        @if (!string.IsNullOrEmpty(PhotoDataUrl))
        {
            <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Secondary" StartIcon="@Icons.Material.Filled.Download" Href="@PhotoDataUrl" Download="@DownloadFileName">
                Foto herunterladen
            </MudButton>
        }
    </MudStack>

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="mt-2">
        <MudButton Variant="Variant.Outlined"
                   Color="MudBlazor.Color.Primary"
                   Disabled="@(_isSegmenting || _isAutoCalibrating || string.IsNullOrEmpty(PhotoDataUrl))"
                   StartIcon="@Icons.Material.Filled.AutoFixHigh"
                   OnClick="RunAutoCalibrationAsync">
            Halo-Auto-Kalibrierung
        </MudButton>
        <MudText Typo="Typo.caption" Class="mud-secondary-text">
            Passt Schwellenwert und Kantenglättung anhand des aktuellen Motivs an.
        </MudText>
        @if (_isAutoCalibrating)
        {
            <MudProgressCircular Indeterminate="true" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Medium" />
        }
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(_autoTuneInfo))
    {
        <MudAlert Severity="Severity.Info" Dense="true">@_autoTuneInfo</MudAlert>
    }

    <MudPaper Class="pa-3 mt-2" Elevation="1">
        <MudStack Spacing="1">
            <MudText Typo="Typo.subtitle2">Performance &amp; Qualität</MudText>
            <MudStack Row="true" Spacing="1">
                <MudSelect T="string"
                           Value="@SegmentationSettings.Options.Quality"
                           ValueChanged="UpdateQualityAsync"
                           Dense="true"
                           Label="Qualität">
                    <MudSelectItem Value="@("auto")">Auto (720p Ziel, dynamisch)</MudSelectItem>
                    <MudSelectItem Value="@("high")">High (900p, beste Kanten)</MudSelectItem>
                    <MudSelectItem Value="@("medium")">Medium (720p, Standard)</MudSelectItem>
                    <MudSelectItem Value="@("low")">Low (540p, Akku-schonend)</MudSelectItem>
                </MudSelect>

                <MudSelect T="string"
                           Value="@SegmentationSettings.Options.BackendPreference"
                           ValueChanged="UpdateBackendAsync"
                           Dense="true"
                           Label="Backend">
                    <MudSelectItem Value="@("auto")">Auto (WebGPU/WebGL → TFJS)</MudSelectItem>
                    <MudSelectItem Value="@("onnx")">ONNX Runtime (GPU bevorzugt)</MudSelectItem>
                    <MudSelectItem Value="@("tfjs")">MediaPipe TFJS Fallback</MudSelectItem>
                </MudSelect>
            </MudStack>

            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudSwitch T="bool"
                           Color="MudBlazor.Color.Primary"
                           Checked="@SegmentationSettings.Options.TemporalSmoothing"
                           CheckedChanged="ToggleTemporalSmoothingAsync">
                    Temporale Glättung
                </MudSwitch>
                <MudSwitch T="bool"
                           Color="MudBlazor.Color.Secondary"
                           Checked="@SegmentationSettings.Options.EnablePerfOverlay"
                           CheckedChanged="TogglePerfOverlayAsync">
                    Live-Profiler-Overlay
                </MudSwitch>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_perfSummary is not null)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mt-2">
            Backend: @_perfSummary.Backend ?? "?" | Qualität: @_perfSummary.Quality (dynamisch: @_perfSummary.DynamicQuality)
            | Auflösung: @_perfSummary.Resolution | Gesamt: @_perfSummary.Total.ToString("F1", CultureInfo.InvariantCulture) ms
        </MudAlert>
    }

    <SegmentationPreview ForegroundDataUrl="@_foreground" BackgroundDataUrl="@_background" IsBusy="@_isSegmenting" OnRetry="RetrySegmentation" />

    @if (HasSegmentationResult)
    {
        <OverlayCarousel OnProceed="HandleOverlayProceed" />

        @if (!string.IsNullOrWhiteSpace(_selectionInfo))
        {
            <MudAlert Severity="Severity.Info" Dense="true">@_selectionInfo</MudAlert>
        }

        @if (_isMerging)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-4" Spacing="1">
                <MudProgressCircular Indeterminate="true" Color="MudBlazor.Color.Primary" Size="MudBlazor.Size.Large" />
                <MudText Typo="Typo.body2">Bild wird zusammengeführt …</MudText>
            </MudStack>
        }

        @if (!string.IsNullOrWhiteSpace(_mergeError))
        {
            <MudAlert Severity="Severity.Error" Dense="true">@_mergeError</MudAlert>
        }

        @if (!string.IsNullOrWhiteSpace(_mergedPhoto))
        {
            <MudPaper Class="photo-preview" Elevation="1">
                <MudStack Spacing="1">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Layers" Color="MudBlazor.Color.Primary" />
                        <MudText Typo="Typo.subtitle1">Zusammengeführtes Ergebnis</MudText>
                    </MudStack>

                    <div class="photo-wrapper">
                        <img src="@_mergedPhoto" alt="Zusammengeführtes Bild" class="photo-image" />
                    </div>

                    <MudStack Row="true" Spacing="2" JustifyContent="JustifyContent.Center" Class="mt-2">
                        <MudButton Variant="Variant.Outlined" Color="MudBlazor.Color.Secondary" StartIcon="@Icons.Material.Filled.Download" Href="@_mergedPhoto" Download="@MergedDownloadFileName">
                            Ergebnis herunterladen
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>
        }
    }
</MudPaper>

@code {
    [Parameter]
    public string? PhotoDataUrl { get; set; }

    [Parameter]
    public EventCallback OnRetake { get; set; }

    private string? _foreground;
    private string? _background;
    private string? _segmentationError;
    private bool _isSegmenting;
    private ElementReference _photoRef;
    private SegmentationFocus? _lastFocus;
    private string? _lastPhotoDataUrl;
    private string? _selectionInfo;
    private string? _mergedPhoto;
    private string? _mergeError;
    private bool _isMerging;
    private bool _isAutoCalibrating;
    private string? _autoTuneInfo;
    private SegmentationPerformance? _perfSummary;

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    [Inject]
    private SegmentationSettings SegmentationSettings { get; set; } = default!;

    [Inject]
    private ImageMergeService ImageMergeService { get; set; } = default!;

    [Inject]
    private SegmentationService SegmentationService { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    private string DownloadFileName => "camera_arcanum_photo.png";
    private string MergedDownloadFileName => "camera_arcanum_merge.png";

    private bool HasSegmentationResult => !string.IsNullOrWhiteSpace(_foreground) && !string.IsNullOrWhiteSpace(_background);

    protected override async Task OnInitializedAsync()
    {
        await SegmentationSettings.EnsureInitializedAsync();
        await base.OnInitializedAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.Equals(PhotoDataUrl, _lastPhotoDataUrl, StringComparison.Ordinal))
        {
            _lastPhotoDataUrl = PhotoDataUrl;
            await ResetSegmentationAsync();
        }
    }

    private async Task HandleImageClick(MouseEventArgs args)
    {
        if (PhotoDataUrl is null || _isSegmenting)
        {
            return;
        }

        var metrics = await EnsureMetricsAsync();
        if (metrics is not null)
        {
            var scaleX = metrics.NaturalWidth / Math.Max(1, metrics.ClientWidth);
            var scaleY = metrics.NaturalHeight / Math.Max(1, metrics.ClientHeight);
            _lastFocus = new SegmentationFocus(args.OffsetX * scaleX, args.OffsetY * scaleY);
        }

        await RunSegmentationAsync();
    }

    private async Task RetrySegmentation()
    {
        await RunSegmentationAsync();
    }

    private async Task RunAutoCalibrationAsync()
    {
        if (PhotoDataUrl is null || _isAutoCalibrating)
        {
            return;
        }

        _segmentationError = null;
        _autoTuneInfo = null;
        _isAutoCalibrating = true;

        try
        {
            var result = await SegmentationService.AutoCalibrateAsync(
                PhotoDataUrl,
                _lastFocus,
                SegmentationSettings.Options);

            await SegmentationSettings.UpdateAsync(result.TunedOptions);

            _autoTuneInfo =
                $"Auto-Kalibrierung aktiv: weiche Kante {result.Stats.SoftEdgeRatio.ToString("P0", CultureInfo.InvariantCulture)}, " +
                $"Übergang {result.Stats.AvgEdgeTransition:F0}, Randleck {result.Stats.BorderLeakRatio.ToString("P1", CultureInfo.InvariantCulture)}. Neue Werte wurden übernommen.";

            Snackbar.Add("Segmentierungs-Parameter automatisch angepasst", Severity.Success);

            await RunSegmentationAsync();
        }
        catch (JSException ex)
        {
            _segmentationError = $"Auto-Kalibrierung fehlgeschlagen: {ex.Message}";
        }
        finally
        {
            _isAutoCalibrating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RunSegmentationAsync()
    {
        if (PhotoDataUrl is null)
        {
            return;
        }

        _segmentationError = null;
        _mergedPhoto = null;
        _mergeError = null;
        _isSegmenting = true;

        try
        {
            var result = await SegmentationService.SegmentPhotoAsync(
                PhotoDataUrl,
                _lastFocus,
                SegmentationSettings.Options);

            _foreground = result.ForegroundDataUrl;
            _background = result.BackgroundDataUrl;
            _perfSummary = await SegmentationService.GetPerformanceSnapshotAsync();
        }
        catch (JSException ex)
        {
            _segmentationError = $"Segmentierung fehlgeschlagen: {ex.Message}";
            _foreground = null;
            _background = null;
            _perfSummary = null;
        }
        finally
        {
            _isSegmenting = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task<ImageMetrics?> EnsureMetricsAsync()
    {
        return await SegmentationService.GetImageMetricsAsync(_photoRef);
    }

    private async Task ResetSegmentationAsync()
    {
        _foreground = null;
        _background = null;
        _segmentationError = null;
        _lastFocus = null;
        _selectionInfo = null;
        _mergedPhoto = null;
        _mergeError = null;
        _isMerging = false;
        _autoTuneInfo = null;
        _isAutoCalibrating = false;
        _perfSummary = null;

        await SegmentationService.ResetAsync();
    }

    private async Task HandleRetake()
    {
        await ResetSegmentationAsync();
        await OnRetake.InvokeAsync();
    }

    private async Task HandleOverlayProceed(OverlayProceedRequest request)
    {
        _selectionInfo = request.UseOriginalBackground
            ? $"Ausgewählte Zwischenschicht: {request.OverlayPath} (Original-Hintergrund)"
            : $"Ausgewählte Zwischenschicht: {request.OverlayPath} (extrahierter Hintergrund)";
        await JS.InvokeVoidAsync("console.log", $"Overlay selection confirmed for {request.OverlayPath} with background {(request.UseOriginalBackground ? "original" : "extracted")}");

        if (!HasSegmentationResult)
        {
            _mergeError = "Es ist kein Segmentierungsergebnis vorhanden.";
            return;
        }

        if (request.UseOriginalBackground && string.IsNullOrWhiteSpace(PhotoDataUrl))
        {
            _mergeError = "Das Originalbild steht nicht mehr zur Verfügung.";
            return;
        }

        _mergeError = null;
        _isMerging = true;

        try
        {
            var focus = _lastFocus is null
                ? (SixLabors.ImageSharp.PointF?)null
                : new SixLabors.ImageSharp.PointF((float)_lastFocus.X, (float)_lastFocus.Y);
            var backgroundSource = request.UseOriginalBackground ? PhotoDataUrl : _background;

            if (string.IsNullOrWhiteSpace(backgroundSource))
            {
                _mergeError = "Es steht kein Hintergrundbild zur Verfügung.";
                _isMerging = false;
                await InvokeAsync(StateHasChanged);
                return;
            }

            await JS.InvokeVoidAsync("console.log", $"[Merge] Start {DateTimeOffset.Now:O} | Overlay {request.OverlayPath} | Hintergrund {(request.UseOriginalBackground ? "Original" : "extrahiert")}");

            var mergeResult = await ImageMergeService.MergeAsync(
                backgroundSource!,
                request.OverlayPath,
                _foreground!,
                focus);

            _mergedPhoto = mergeResult.DataUrl;
            await LogMergeDiagnosticsAsync(mergeResult);
        }
        catch (Exception ex)
        {
            _mergeError = $"Zusammenführung fehlgeschlagen: {ex.Message}";
            _mergedPhoto = null;
        }
        finally
        {
            _isMerging = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        await SegmentationService.DisposeAsync();
    }

    private async Task UpdateQualityAsync(string? quality)
    {
        if (string.IsNullOrWhiteSpace(quality))
        {
            return;
        }

        var next = CloneOptions();
        next.Quality = quality;
        await SegmentationSettings.UpdateAsync(next);
        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateBackendAsync(string? backend)
    {
        if (string.IsNullOrWhiteSpace(backend))
        {
            return;
        }

        var next = CloneOptions();
        next.BackendPreference = backend;
        await SegmentationSettings.UpdateAsync(next);
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleTemporalSmoothingAsync(bool value)
    {
        var next = CloneOptions();
        next.TemporalSmoothing = value;
        await SegmentationSettings.UpdateAsync(next);
        await InvokeAsync(StateHasChanged);
    }

    private async Task TogglePerfOverlayAsync(bool value)
    {
        var next = CloneOptions();
        next.EnablePerfOverlay = value;
        await SegmentationSettings.UpdateAsync(next);
        await InvokeAsync(StateHasChanged);
    }

    private async Task LogMergeDiagnosticsAsync(MergeResult mergeResult)
    {
        await JS.InvokeVoidAsync(
            "console.groupCollapsed",
            $"[Merge] {mergeResult.Pipeline} · Gesamt: {mergeResult.TotalDurationMs} ms");

        foreach (var step in mergeResult.Timings)
        {
            await JS.InvokeVoidAsync(
                "console.log",
                $"{DateTimeOffset.Now:O} | {step.Step}: +{step.DurationMs} ms (t={step.ElapsedMs} ms)");
        }

        await JS.InvokeVoidAsync("console.groupEnd");
    }

    private SegmentationOptions CloneOptions()
    {
        var current = SegmentationSettings.Options;
        return new SegmentationOptions
        {
            ModelType = current.ModelType,
            SegmentationThreshold = current.SegmentationThreshold,
            MaskBlurAmount = current.MaskBlurAmount,
            DilationRadius = current.DilationRadius,
            ErosionRadius = current.ErosionRadius,
            InnerFeatherRadius = current.InnerFeatherRadius,
            OuterFeatherRadius = current.OuterFeatherRadius,
            Quality = current.Quality,
            BackendPreference = current.BackendPreference,
            TemporalSmoothing = current.TemporalSmoothing,
            TemporalSmoothingAlpha = current.TemporalSmoothingAlpha,
            EnableEdgeRefinement = current.EnableEdgeRefinement,
            EnableSharpening = current.EnableSharpening,
            EnablePerfOverlay = current.EnablePerfOverlay,
        };
    }
}
